AGENTPROOF_ENVIRONMENT=local
APP_BASE_URL=http://localhost:8000

DJANGO_SETTINGS_MODULE=agentproof_backend.config.settings.local
DJANGO_SECRET_KEY=replace-with-a-generated-secret
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
DJANGO_LOG_LEVEL=INFO

DATABASE_URL=postgresql://agentproof:agentproof@localhost:5432/agentproof #pragma: allowlist secret

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

OBJECT_STORAGE_BACKEND=filesystem

# Required only when OBJECT_STORAGE_BACKEND=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=
AWS_S3_ENDPOINT_URL=

SENTRY_DSN=
