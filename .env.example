AGENTPROOF_ENVIRONMENT=local

DJANGO_SETTINGS_MODULE=agentproof_backend.config.settings.local
DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

